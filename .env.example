# ── Meta WhatsApp Business API ──────────────────────────────────────────────
# From Meta Developer Console → Your App → Settings
META_APP_ID=your_facebook_app_id
META_APP_SECRET=your_facebook_app_secret

# Arbitrary string — must match what you set in Meta Developer Console → Webhooks
META_WHATSAPP_VERIFY_TOKEN=engageclient-verify

# ── Anthropic (for AI agent responses) ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/engageclient

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_STARTER=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_GROWTH=price_xxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_PRICE_SCALE=price_xxxxxxxxxxxxxxxxxxxxxxxx

# ── App URLs ──────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:5173
NODE_ENV=development
PORT=3000
